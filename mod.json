	"id": "geo_mzngd.gdskill",
	"name": "Geometry Dash: Skill",
	"version": "v1.0.0",
	"developer": "GeomznGD",
	"contributors": ["jarvisdevil (og code)"]
	"description": "Adds a new 'Skill' button to the creator page.",
	"dependencies": {
		"geode.node-ids": {
			"version": ">=1.21.1",
			"importance": "required"
		}
	},
	"settings": {
		"cheats": {
			"type": "title",
			"name": "Cheats",
			"description": "Enable cheats."
		},
		"unlock-all": {
            "type": "bool",
            "name": "Unlock All",
            "description": "Unlocks all levels in GD Skill.",
